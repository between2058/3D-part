# =============================================================================
# P3-SAM — Machine-specific configuration
#
# Usage:
#   cp P3-SAM/.env.example P3-SAM/.env
#   vim P3-SAM/.env          # 填入這台機器的實際路徑
#
# .env 已被 .gitignore 排除，不會 commit 進版本控制。
# .env.example 是範本，請 commit 進 git。
# =============================================================================

# ── HuggingFace model cache 在 host 上的路徑 ─────────────────────────────────
# 容器內固定掛載到 /root/.cache/huggingface
#
# 伺服器（共用 NAS）：
#   HF_CACHE_HOST_PATH=/pegaai/model_team/huggingface_cache
#
# 本機開發（自動建立）：
#   HF_CACHE_HOST_PATH=./weights/huggingface
HF_CACHE_HOST_PATH=./weights/huggingface

# ── Log 輸出目錄在 host 上的路徑 ─────────────────────────────────────────────
# 容器內固定掛載到 /app/logs
# 每天 rotate，保留 14 天（app.log / access.log / uvicorn.log）
LOGS_HOST_PATH=./logs
